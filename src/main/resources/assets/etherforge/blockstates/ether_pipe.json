{
  "multipart": [
    {
      "apply": { "model": "etherforge:pipe/pipe_core" }
    },
    {
      "when": { "south": "true" },
      "apply": {
        "model": "etherforge:pipe/pipe_arm"
      }
    },
    {
      "when": { "north": "true" },
      "apply": {
        "model": "etherforge:pipe/pipe_arm",
        "y": 180
      }
    },
    {
      "when": { "east": "true" },
      "apply": {
        "model": "etherforge:pipe/pipe_arm",
        "y": 270
      }
    },
    {
      "when": { "west": "true" },
      "apply": {
        "model": "etherforge:pipe/pipe_arm",
        "y": 90
      }
    },
    {
      "when": { "up": "true" },
      "apply": {
        "model": "etherforge:pipe/pipe_arm",
        "x": 270
      }
    },
    {
      "when": { "down": "true" },
      "apply": {
        "model": "etherforge:pipe/pipe_arm",
        "x": 90
      }
    }
  ]
}